{
  "id": "day-01",
  "day": 1,
  "kicker": "SIMULATION · 01",
  "title": "You Will Never Find The Exit",
  "fps": 30,
  "width": 1080,
  "height": 1920,
  "durationInFrames": 1003,
  "palette": "void",
  "voice": "en-US-GuyNeural",
  "cta": "Follow for the questions that don't let you sleep.",
  "captions": [
    {
      "text": "If we live in",
      "startMs": 100,
      "endMs": 1502
    },
    {
      "text": "a simulation,",
      "startMs": 1502,
      "endMs": 2203
    },
    {
      "text": "you will never find",
      "startMs": 2203,
      "endMs": 3604
    },
    {
      "text": "the exit.",
      "startMs": 3604,
      "endMs": 4305
    },
    {
      "text": "Every test you run",
      "startMs": 4255,
      "endMs": 5662
    },
    {
      "text": "is part of the",
      "startMs": 5662,
      "endMs": 7068
    },
    {
      "text": "program.",
      "startMs": 7068,
      "endMs": 7420
    },
    {
      "text": "The ruler that measures",
      "startMs": 7420,
      "endMs": 8604
    },
    {
      "text": "the wall is made",
      "startMs": 8604,
      "endMs": 9789
    },
    {
      "text": "of the same code",
      "startMs": 9789,
      "endMs": 10973
    },
    {
      "text": "as the wall.",
      "startMs": 10973,
      "endMs": 11861
    },
    {
      "text": "The cage is not",
      "startMs": 11861,
      "endMs": 13049
    },
    {
      "text": "locked —",
      "startMs": 13049,
      "endMs": 13643
    },
    {
      "text": "it has no door",
      "startMs": 13643,
      "endMs": 14831
    },
    {
      "text": "at all.",
      "startMs": 14831,
      "endMs": 15425
    },
    {
      "text": "But here is what",
      "startMs": 15425,
      "endMs": 17331
    },
    {
      "text": "changes everything.",
      "startMs": 17331,
      "endMs": 18284
    },
    {
      "text": "If this is the",
      "startMs": 18284,
      "endMs": 19658
    },
    {
      "text": "only reality you can",
      "startMs": 19658,
      "endMs": 21032
    },
    {
      "text": "reach, and it stays",
      "startMs": 21032,
      "endMs": 22407
    },
    {
      "text": "consistent, then the pain",
      "startMs": 22407,
      "endMs": 23781
    },
    {
      "text": "still hurts.",
      "startMs": 23781,
      "endMs": 24468
    },
    {
      "text": "The love still lands.",
      "startMs": 24468,
      "endMs": 26781
    },
    {
      "text": "The substrate never cheapened",
      "startMs": 26781,
      "endMs": 28465
    },
    {
      "text": "a single moment of",
      "startMs": 28465,
      "endMs": 30150
    },
    {
      "text": "it.",
      "startMs": 30150,
      "endMs": 30571
    }
  ]
}