{
  "id": "day-02",
  "day": 2,
  "kicker": "THE COPY · 02",
  "title": "The Upload Isn't You",
  "fps": 30,
  "width": 1080,
  "height": 1920,
  "durationInFrames": 1245,
  "palette": "signal",
  "voice": "en-US-EricNeural",
  "cta": "Follow if your own mind unsettles you.",
  "captions": [
    {
      "text": "They say one day",
      "startMs": 100,
      "endMs": 1670
    },
    {
      "text": "you'll upload your mind",
      "startMs": 1670,
      "endMs": 3240
    },
    {
      "text": "and live forever.",
      "startMs": 3240,
      "endMs": 4418
    },
    {
      "text": "But picture the machine",
      "startMs": 4368,
      "endMs": 6157
    },
    {
      "text": "that scans your brain,",
      "startMs": 6157,
      "endMs": 7947
    },
    {
      "text": "copies every neuron,",
      "startMs": 7947,
      "endMs": 9289
    },
    {
      "text": "and switches on.",
      "startMs": 9289,
      "endMs": 10631
    },
    {
      "text": "That copy wakes up",
      "startMs": 10631,
      "endMs": 12258
    },
    {
      "text": "certain it is you.",
      "startMs": 12258,
      "endMs": 13884
    },
    {
      "text": "It has your memories,",
      "startMs": 13884,
      "endMs": 15701
    },
    {
      "text": "your voice,",
      "startMs": 15701,
      "endMs": 16610
    },
    {
      "text": "your fear of dying.",
      "startMs": 16610,
      "endMs": 18427
    },
    {
      "text": "And meanwhile,",
      "startMs": 18427,
      "endMs": 19437
    },
    {
      "text": "you are still standing",
      "startMs": 19437,
      "endMs": 21457
    },
    {
      "text": "there.",
      "startMs": 21457,
      "endMs": 21962
    },
    {
      "text": "Or you died in",
      "startMs": 21962,
      "endMs": 23575
    },
    {
      "text": "the scan.",
      "startMs": 23575,
      "endMs": 24381
    },
    {
      "text": "Nothing transferred.",
      "startMs": 24381,
      "endMs": 26586
    },
    {
      "text": "You didn't become immortal.",
      "startMs": 26586,
      "endMs": 28991
    },
    {
      "text": "You built a stranger",
      "startMs": 28991,
      "endMs": 30477
    },
    {
      "text": "who inherits your life",
      "startMs": 30477,
      "endMs": 31963
    },
    {
      "text": "and your name.",
      "startMs": 31963,
      "endMs": 33077
    },
    {
      "text": "The upload isn't you.",
      "startMs": 33077,
      "endMs": 35322
    },
    {
      "text": "It's a successor who",
      "startMs": 35322,
      "endMs": 36976
    },
    {
      "text": "only thinks it is.",
      "startMs": 36976,
      "endMs": 38629
    }
  ]
}