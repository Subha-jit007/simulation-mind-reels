# dependencies
node_modules/
studio/node_modules/

# auto-generated Pollinations scene cache (regenerated each render)
studio/public/images/auto/

# local reference clone only (80MB, has its own git) — not needed in the repo
toolkit/

# build artifacts
studio/out/
renders/.work/

# rendered videos live as GitHub Release assets, not in git (keeps repo small)
renders/*.mp4

# paid products + profile assets stay local (public repo = don't give them away free)
product/
profile/
studio/_wp.json

# keep the folder + the source data + posting state
!renders/.gitkeep
